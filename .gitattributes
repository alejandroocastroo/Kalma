# Forzar LF en todos los archivos de texto
* text=auto eol=lf

# Shell scripts — crítico para Docker/Linux
*.sh text eol=lf

# Python / SQL / JS / TS / config
*.py text eol=lf
*.sql text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Binarios — no tocar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
