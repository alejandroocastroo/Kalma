# ─────────────────────────────────────────────────────────────
# Kalma – Variables de entorno PRODUCCIÓN (usekalma.com)
# Renombrar a .env en el VPS y llenar los valores marcados con <>
# ─────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────
POSTGRES_USER=kalma
POSTGRES_PASSWORD=<genera una clave segura>
POSTGRES_DB=kalma

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=<genera una clave segura>

# ── Backend / FastAPI ─────────────────────────────────────────
# Genera con: openssl rand -hex 32
SECRET_KEY=<clave de 32+ caracteres>
ENVIRONMENT=production
ALLOWED_ORIGINS=https://usekalma.com,https://app.usekalma.com

# ── Frontend / Next.js ────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.usekalma.com
NODE_ENV=production
