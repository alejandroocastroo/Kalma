# ─────────────────────────────────────────
# Kalma – Variables de entorno
# Copiar como .env y ajustar valores
# ─────────────────────────────────────────

# ── Base de datos ──────────────────────────
POSTGRES_USER=kalma
POSTGRES_PASSWORD=kalmapassword
POSTGRES_DB=kalma

# ── Redis ──────────────────────────────────
REDIS_PASSWORD=kalmaRedis123

# ── Backend / FastAPI ──────────────────────
SECRET_KEY=cambia-esta-clave-en-produccion-debe-tener-minimo-32-caracteres
ENVIRONMENT=development
# Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://app.usekalma.com,https://mantra.usekalma.com

# ── Frontend / Next.js ─────────────────────
# URL pública del backend (sin /api)
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development

# ── WhatsApp Business API (pendiente) ──────
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=

# ── Dominio de producción ──────────────────
# DOMAIN=usekalma.com
